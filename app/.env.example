# Copy this to .env for local development
# .env is gitignored — never commit real secrets

NODE_ENV=development
PORT=3000

# MongoDB — local Docker Compose
MONGO_URI=mongodb://localhost:27017/products

# OpenTelemetry
OTEL_SERVICE_NAME=nodejs-product-catalog
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LOG_LEVEL=info

# Artifactory (used by Jenkins, not the app itself)
# ARTIFACTORY_URL=https://your-instance.jfrog.io/artifactory
# ARTIFACTORY_USER=your-user
# ARTIFACTORY_TOKEN=your-api-token
